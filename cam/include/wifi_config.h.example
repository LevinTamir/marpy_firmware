#pragma once

// =================== Wi-Fi config ===================
// 1. Copy this file:  cp include/wifi_config.h.example include/wifi_config.h
// 2. Fill in your values below
// 3. wifi_config.h is git-ignored, your credentials stay local
//
// The cam serves an MJPEG stream over HTTP, so it just needs Wi-Fi
// credentials. No agent IP, no port; the bridge node finds the cam via
// mDNS at marpy-cam.local (or you can give the bridge an IP).

static char WIFI_SSID[] = "YOUR_WIFI_SSID";
static char WIFI_PSK[]  = "YOUR_WIFI_PASSWORD";
